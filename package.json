{
  "name": "favicon-extract",
  "version": "0.1.0",
  "description": "A tiny library that discovers, normalizes, and resolves the best favicon for a URL.",
  "author": "Lior Matza",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hierophantom/favicon-extract.git"
  },
  "homepage": "https://github.com/hierophantom/favicon-extract#readme",
  "bugs": {
    "url": "https://github.com/hierophantom/favicon-extract/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:site": "node scripts/prepare-site.mjs",
    "test": "vitest run",
    "dev": "vitest",
    "demo": "node demo/server.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "favicon",
    "icons",
    "website",
    "url",
    "extract",
    "favicon-resolver"
  ],
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}