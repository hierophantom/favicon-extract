{
  "name": "favicon-extract",
  "version": "0.1.0",
  "description": "A tiny library that discovers, normalizes, and resolves the best favicon for a URL.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "dev": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "favicon",
    "icons",
    "website",
    "url",
    "extract"
  ],
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}